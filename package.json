    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "style-dictionary": "^5.5.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
